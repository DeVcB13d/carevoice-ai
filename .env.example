# =============================================================================
# CareVoice AI — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# Get these from https://cloud.livekit.io → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# ── Tavus (AI Video Avatar) ───────────────────────────────────────────────────
# Get these from https://platform.tavus.io
TAVUS_API_KEY=your_tavus_api_key_here
TAVUS_REPLICA_ID=r_xxxxxxxxxxxxxxxx
TAVUS_PERSONA_ID=p_xxxxxxxxxxxxxxxx    # Optional — leave blank to use default

# ── OpenAI (LLM + Summary Generation) ────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Deepgram (Speech-to-Text) ─────────────────────────────────────────────────
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: leave as default (uses voice_agent.db in project root)
# Production (Render disk): set to /data/voice_agent.db
DB_PATH=voice_agent.db

# ── CORS (Production Only) ────────────────────────────────────────────────────
# Set this to your deployed frontend URL in production
ALLOWED_ORIGIN=http://localhost:5173
