# =============================================================================
# CareVoice AI — .gitignore
# =============================================================================

# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.spec
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ── Testing & Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.xml
coverage.xml
nosetests.xml

# ── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*
!frontend/.env.example
.npm
*.tsbuildinfo

# ── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
.gemini/
~/
temp/
tmp/
